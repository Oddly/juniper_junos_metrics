resource.url: {{#if use_https}}https{{else}}http{{/if}}://{{username}}:{{password}}@{{host}}/rpc/get-bgp-summary-information@format=json
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
redact:
  fields:
    - resource.url
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "bgp-information" in body && size(body["bgp-information"]) > 0
        && "bgp-peer" in body["bgp-information"][0] ?
          body["bgp-information"][0].as(info,
            {"events": info["bgp-peer"].map(peer, {
              "message": {
                "group-count": info["group-count"],
                "peer-count": info["peer-count"],
                "down-peer-count": info["down-peer-count"],
                "peer": peer
              }.encode_json(),
              "juniper.junos.bgp.peer.address": "peer-address" in peer && size(peer["peer-address"]) > 0 ? string(peer["peer-address"][0]["data"]) : "unknown",
              "juniper.junos.bgp.peer.as": "peer-as" in peer && size(peer["peer-as"]) > 0 ? string(peer["peer-as"][0]["data"]) : "0",
            })}
          )
        :
          {"events": [{"message": "debug: body structure mismatch", "juniper.junos.bgp.peer.address": "debug", "juniper.junos.bgp.peer.as": "debug"}]}
      )
    :
      {"events": [{"message": "debug: non-200 status " + string(resp.StatusCode), "juniper.junos.bgp.peer.address": "debug", "juniper.junos.bgp.peer.as": "debug"}]}
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
