resource.url: {{host}}/rpc/get-bgp-summary-information@format=json
auth:
  basic:
    user: {{username}}
    password: {{password}}
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "bgp-information" in body && size(body["bgp-information"]) > 0
        && "bgp-peer" in body["bgp-information"][0] ?
          body["bgp-information"][0].as(info,
            {"events": info["bgp-peer"].map(peer, {
              "message": {
                "group-count": info["group-count"],
                "peer-count": info["peer-count"],
                "down-peer-count": info["down-peer-count"],
                "peer": peer
              }.encode_json(),
            })}
          )
        :
          {"events": []}
      )
    :
      {"events": []}
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
