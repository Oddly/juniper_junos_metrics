resource.url: {{host}}/rpc/get-alarm-information@format=json
auth:
  basic:
    user: {{username}}
    password: {{password}}
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "alarm-information" in body && size(body["alarm-information"]) > 0
        && "alarm-detail" in body["alarm-information"][0] ?
          {"events": body["alarm-information"][0]["alarm-detail"].map(alarm, {
            "message": alarm.encode_json(),
          })}
        :
          {"events": []}
      )
    :
      {"events": []}
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
