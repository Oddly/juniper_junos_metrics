resource.url: {{host}}/rpc/get-interface-information@format=json
auth.basic.user: {{username}}
auth.basic.password: {{password}}
resource.ssl.verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "interface-information" in body && size(body["interface-information"]) > 0
        && "physical-interface" in body["interface-information"][0] ?
          body["interface-information"][0]["physical-interface"].map(iface, {
            "message": iface.encode_json(),
          })
        :
          []
      )
    :
      []
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
