resource.url: {{#if use_https}}https{{else}}http{{/if}}://{{username}}:{{password}}@{{host}}/rpc/get-interface-information@format=json
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
redact:
  fields:
    - resource.url
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "interface-information" in body && size(body["interface-information"]) > 0
        && "physical-interface" in body["interface-information"][0] ?
          {"events": body["interface-information"][0]["physical-interface"].map(iface, {
            "message": iface.encode_json(),
            "observer.name": "{{host}}",
            "juniper.junos.interfaces.name": "name" in iface && size(iface["name"]) > 0 ? string(iface["name"][0]["data"]) : "unknown",
          })}
        :
          {"events": [{"message": "debug: body structure mismatch", "observer.name": "{{host}}", "juniper.junos.interfaces.name": "debug"}]}
      )
    :
      {"events": [{"message": "debug: non-200 status " + string(resp.StatusCode), "observer.name": "{{host}}", "juniper.junos.interfaces.name": "debug"}]}
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
