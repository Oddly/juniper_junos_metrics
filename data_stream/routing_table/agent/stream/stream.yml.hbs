resource.url: {{#if use_https}}https{{else}}http{{/if}}://{{username}}:{{password}}@{{host}}/rpc/get-route-summary-information@format=json
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
redact:
  fields:
    - resource.url
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "route-summary-information" in body && size(body["route-summary-information"]) > 0 ?
          body["route-summary-information"][0].as(info,
            "route-table" in info ?
              {"events": info["route-table"].map(rt, {
                "message": {"router-id": info["router-id"], "route-table": rt}.encode_json(),
                "juniper.junos.routing_table.router_id": "router-id" in info && size(info["router-id"]) > 0 ? string(info["router-id"][0]["data"]) : "unknown",
                "juniper.junos.routing_table.table_name": "table-name" in rt && size(rt["table-name"]) > 0 ? string(rt["table-name"][0]["data"]) : "unknown",
              })}
            :
              {"events": [{"message": "debug: body structure mismatch", "juniper.junos.routing_table.router_id": "debug", "juniper.junos.routing_table.table_name": "debug"}]}
          )
        :
          {"events": [{"message": "debug: body structure mismatch", "juniper.junos.routing_table.router_id": "debug", "juniper.junos.routing_table.table_name": "debug"}]}
      )
    :
      {"events": [{"message": "debug: non-200 status " + string(resp.StatusCode), "juniper.junos.routing_table.router_id": "debug", "juniper.junos.routing_table.table_name": "debug"}]}
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
