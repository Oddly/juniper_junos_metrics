resource.url: {{host}}/rpc/get-system-storage@format=json
auth:
  basic:
    user: {{username}}
    password: {{password}}
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "system-storage-information" in body && size(body["system-storage-information"]) > 0
        && "filesystem" in body["system-storage-information"][0] ?
          {"events": body["system-storage-information"][0]["filesystem"].map(fs, {
            "message": fs.encode_json(),
          })}
        :
          {"events": []}
      )
    :
      {"events": []}
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
