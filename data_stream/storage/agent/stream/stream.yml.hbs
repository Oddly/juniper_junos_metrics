resource.url: {{#if use_https}}https{{else}}http{{/if}}://{{username}}:{{password}}@{{host}}/rpc/get-system-storage@format=json
resource:
  ssl:
    verification_mode: {{ssl_verification_mode}}
resource.timeout: 30s
state:
  initial: {}
redact:
  fields:
    - resource.url
program: |
  request("GET", state.url).do_request().as(resp,
    resp.StatusCode == 200 ?
      bytes(resp.Body).decode_json().as(body,
        "system-storage-information" in body && size(body["system-storage-information"]) > 0
        && "filesystem" in body["system-storage-information"][0] ?
          {"events": body["system-storage-information"][0]["filesystem"].map(fs, {
            "message": fs.encode_json(),
            "juniper.junos.storage.filesystem_name": "filesystem-name" in fs && size(fs["filesystem-name"]) > 0 ? string(fs["filesystem-name"][0]["data"]) : "unknown",
            "juniper.junos.storage.mounted_on": "mounted-on" in fs && size(fs["mounted-on"]) > 0 ? string(fs["mounted-on"][0]["data"]) : "unknown",
          })}
        :
          {"events": [{"message": "debug: body structure mismatch", "juniper.junos.storage.filesystem_name": "debug", "juniper.junos.storage.mounted_on": "debug"}]}
      )
    :
      {"events": [{"message": "debug: non-200 status " + string(resp.StatusCode), "juniper.junos.storage.filesystem_name": "debug", "juniper.junos.storage.mounted_on": "debug"}]}
  )
interval: {{period}}
{{#if tags}}
tags:
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{/if}}
